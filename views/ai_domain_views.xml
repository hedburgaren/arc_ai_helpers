<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tree View -->
    <record id="view_arc_ai_domain_list" model="ir.ui.view">
        <field name="name">arc.ai.domain.list</field>
        <field name="model">arc.ai.domain</field>
        <field name="arch" type="xml">
            <list string="AI Domains" decoration-muted="not active">
                <field name="name"/>
                <field name="display_name"/>
                <field name="domain_type"/>
                <field name="partner_id"/>
                <field name="monthly_token_usage" sum="Total"/>
                <field name="estimated_monthly_cost" sum="Total" widget="monetary"/>
                <field name="billing_rate"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_arc_ai_domain_form" model="ir.ui.view">
        <field name="name">arc.ai.domain.form</field>
        <field name="model">arc.ai.domain</field>
        <field name="arch" type="xml">
            <form string="AI Domain">
                <header>
                    <button name="action_sync_from_nocodb" type="object" string="↓ Sync from NocoDB" class="btn-secondary"/>
                    <button name="action_sync_to_nocodb" type="object" string="↑ Push to NocoDB" class="btn-secondary"/>
                    <button name="action_refresh_usage" type="object" string="🔄 Refresh Usage" class="btn-secondary"/>
                    <button name="action_create_invoice" type="object" string="📄 Create Invoice" class="btn-primary" invisible="not partner_id or monthly_token_usage == 0"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(base.action_partner_form)d" type="action" class="oe_stat_button" icon="fa-building" invisible="not partner_id">
                            <field name="partner_id" widget="statinfo" string="Customer"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="e.g. plastshop"/>
                        </h1>
                        <field name="display_name" placeholder="e.g. PlastShop AB"/>
                    </div>
                    <group>
                        <group string="Basic Info">
                            <field name="domain_type"/>
                            <field name="url" widget="url"/>
                            <field name="slack_channel_id"/>
                            <field name="qdrant_collection" readonly="1"/>
                            <field name="workers"/>
                            <field name="active"/>
                        </group>
                        <group string="Billing">
                            <field name="partner_id"/>
                            <field name="product_id"/>
                            <field name="billing_rate"/>
                            <field name="billing_email"/>
                            <field name="token_limit"/>
                            <field name="last_invoice_date"/>
                        </group>
                    </group>
                    <group string="Usage Statistics" col="4">
                        <field name="token_count"/>
                        <field name="monthly_token_usage"/>
                        <field name="estimated_monthly_cost" widget="monetary"/>
                        <field name="last_sync"/>
                    </group>
                    <notebook>
                        <page string="Brand Profile" name="brand">
                            <group>
                                <group>
                                    <field name="brand_tagline" placeholder="Short slogan..."/>
                                    <field name="tone_of_voice" placeholder="e.g. Professional, friendly"/>
                                    <field name="industry"/>
                                </group>
                                <group>
                                    <field name="brand_colors" placeholder="#0066CC (primary), #FF6600 (accent)"/>
                                    <field name="competitors"/>
                                </group>
                            </group>
                            <group>
                                <field name="brand_description" placeholder="2-3 sentences about what the company does..."/>
                            </group>
                            <group>
                                <field name="target_audience" placeholder="Who are the customers? Industries, roles, company size..."/>
                            </group>
                            <group>
                                <field name="key_products" placeholder="Main products or services..."/>
                            </group>
                            <group>
                                <field name="unique_selling_points" placeholder="What makes this company unique?"/>
                            </group>
                        </page>
                        <page string="AI Guidelines" name="guidelines">
                            <group>
                                <field name="content_guidelines" placeholder="Rules for AI-generated content..."/>
                            </group>
                            <group>
                                <field name="forbidden_words" placeholder="Comma-separated words to avoid"/>
                            </group>
                            <group>
                                <field name="voice_prompt" placeholder="Custom voice/personality for this domain..."/>
                            </group>
                        </page>
                        <page string="Technical" name="technical">
                            <group>
                                <group>
                                    <field name="nocodb_id" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_arc_ai_domain_search" model="ir.ui.view">
        <field name="name">arc.ai.domain.search</field>
        <field name="model">arc.ai.domain</field>
        <field name="arch" type="xml">
            <search string="Search Domains">
                <field name="name"/>
                <field name="display_name"/>
                <field name="partner_id"/>
                <filter name="active" string="Active" domain="[('active', '=', True)]"/>
                <filter name="billable" string="Billable" domain="[('partner_id', '!=', False), ('billing_rate', '>', 0)]"/>
                <filter name="has_usage" string="Has Usage" domain="[('monthly_token_usage', '>', 0)]"/>
                <separator/>
                <filter name="archived" string="Archived" domain="[('active', '=', False)]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type" context="{'group_by': 'domain_type'}"/>
                    <filter name="group_partner" string="Customer" context="{'group_by': 'partner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_arc_ai_domain_kanban" model="ir.ui.view">
        <field name="name">arc.ai.domain.kanban</field>
        <field name="model">arc.ai.domain</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="display_name"/>
                <field name="monthly_token_usage"/>
                <field name="estimated_monthly_cost"/>
                <field name="partner_id"/>
                <field name="brand_colors"/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex flex-column">
                            <strong><field name="display_name"/></strong>
                            <small class="text-muted"><field name="name"/></small>
                            <div class="mt-2">
                                <span class="badge bg-primary"><field name="monthly_token_usage"/> tokens</span>
                                <span class="badge bg-success" t-if="record.estimated_monthly_cost.raw_value > 0">
                                    <field name="estimated_monthly_cost" widget="monetary"/> SEK
                                </span>
                            </div>
                            <div class="mt-1" t-if="record.partner_id.value">
                                <small><i class="fa fa-building"/> <field name="partner_id"/></small>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action -->
    <record id="action_arc_ai_domain" model="ir.actions.act_window">
        <field name="name">AI Domains</field>
        <field name="res_model">arc.ai.domain</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_arc_ai_domain_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AI Domain
            </p>
            <p>
                AI Domains represent tenants/customers that use your AI services.
                Each domain has its own brand profile, usage tracking, and billing settings.
            </p>
        </field>
    </record>
</odoo>
