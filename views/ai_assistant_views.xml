<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- AI Assistant List View -->
    <record id="ai_assistant_view_list" model="ir.ui.view">
        <field name="name">ai.assistant.list</field>
        <field name="model">ai.assistant</field>
        <field name="arch" type="xml">
            <list string="AI Assistants">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="email"/>
                <field name="specialization" widget="badge"/>
                <field name="language"/>
                <field name="task_count"/>
                <field name="last_activity"/>
                <field name="active" column_invisible="1"/>
            </list>
        </field>
    </record>

    <!-- AI Assistant Form View -->
    <record id="ai_assistant_view_form" model="ir.ui.view">
        <field name="name">ai.assistant.form</field>
        <field name="model">ai.assistant</field>
        <field name="arch" type="xml">
            <form string="AI Assistant">
                <header>
                    <button name="action_send_test_message" type="object" string="Test" class="btn-secondary"/>
                    <button name="action_create_odoo_user" type="object" string="Create Odoo User" 
                            class="btn-primary" invisible="user_id"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_tasks" type="object" class="oe_stat_button" icon="fa-tasks">
                            <field name="task_count" widget="statinfo" string="Tasks"/>
                        </button>
                        <button name="action_view_logs" type="object" class="oe_stat_button" icon="fa-history">
                            <field name="message_count_ai" widget="statinfo" string="Messages"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Archived" bg_color="text-bg-danger" invisible="active"/>
                    <field name="image_128" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g., Alex"/></h1>
                        <field name="email" placeholder="e.g., alex@plastshop.se"/>
                    </div>
                    <group>
                        <group string="Identity">
                            <field name="specialization"/>
                            <field name="sub_specialization" placeholder="e.g., Blog Writer, Translator"/>
                            <field name="language"/>
                            <field name="description"/>
                        </group>
                        <group string="Company &amp; User">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="create_odoo_user"/>
                            <field name="user_id"/>
                            <field name="employee_id" invisible="1"/>
                            <field name="active"/>
                            <field name="last_activity" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Persona" name="persona">
                            <group>
                                <field name="persona_prompt" placeholder="System prompt that defines personality and behavior..."/>
                            </group>
                        </page>
                        <page string="Integrations" name="integrations">
                            <group>
                                <group string="Slack">
                                    <field name="slack_user_id"/>
                                    <field name="slack_channel_ids"/>
                                </group>
                                <group string="n8n">
                                    <field name="n8n_workflow_id"/>
                                    <field name="n8n_webhook_url"/>
                                </group>
                            </group>
                            <group>
                                <group string="Gmail">
                                    <field name="gmail_label" placeholder="e.g., alex"/>
                                    <field name="gmail_alias"/>
                                </group>
                            </group>
                        </page>
                        <page string="External Targets" name="external_targets">
                            <group>
                                <group string="Target Configuration">
                                    <field name="target_type"/>
                                </group>
                            </group>
                            <group invisible="target_type != 'wordpress'">
                                <group string="WordPress Settings">
                                    <field name="wordpress_site_url" placeholder="https://chrille.nu"/>
                                    <field name="wordpress_user"/>
                                </group>
                            </group>
                            <group invisible="target_type != 'postiz'">
                                <group string="Postiz Settings">
                                    <field name="postiz_brand_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="AI Configuration" name="ai_config">
                            <group>
                                <group string="Provider">
                                    <field name="ai_provider"/>
                                    <field name="ai_model" placeholder="e.g., gpt-4, claude-3-opus"/>
                                    <field name="temperature"/>
                                </group>
                                <group string="Memory">
                                    <field name="qdrant_collection"/>
                                    <field name="context_window"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- AI Assistant Kanban View -->
    <record id="ai_assistant_view_kanban" model="ir.ui.view">
        <field name="name">ai.assistant.kanban</field>
        <field name="model">ai.assistant</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="name"/>
                <field name="email"/>
                <field name="specialization"/>
                <field name="image_128"/>
                <field name="task_count"/>
                <templates>
                    <t t-name="card">
                        <aside>
                            <field name="image_128" widget="image" options="{'preview_image': 'image_128'}"/>
                        </aside>
                        <main>
                            <field name="name" class="fw-bold fs-5"/>
                            <field name="email" class="text-muted"/>
                            <div class="mt-2">
                                <field name="specialization" widget="badge"/>
                            </div>
                            <div class="mt-2 text-muted">
                                <span><field name="task_count"/> tasks</span>
                            </div>
                        </main>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- AI Assistant Search View -->
    <record id="ai_assistant_view_search" model="ir.ui.view">
        <field name="name">ai.assistant.search</field>
        <field name="model">ai.assistant</field>
        <field name="arch" type="xml">
            <search string="AI Assistants">
                <field name="name"/>
                <field name="email"/>
                <field name="specialization"/>
                <filter string="Active" name="active" domain="[('active', '=', True)]"/>
                <filter string="Archived" name="archived" domain="[('active', '=', False)]"/>
                <separator/>
                <filter string="Content" name="content" domain="[('specialization', '=', 'content')]"/>
                <filter string="Sales" name="sales" domain="[('specialization', '=', 'sales')]"/>
                <filter string="Support" name="support" domain="[('specialization', '=', 'support')]"/>
                <group expand="0" string="Group By">
                    <filter string="Specialization" name="group_specialization" context="{'group_by': 'specialization'}"/>
                    <filter string="Language" name="group_language" context="{'group_by': 'language'}"/>
                    <filter string="Company" name="group_company" context="{'group_by': 'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- AI Assistant Action -->
    <record id="ai_assistant_action" model="ir.actions.act_window">
        <field name="name">AI Assistants</field>
        <field name="res_model">ai.assistant</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="search_view_id" ref="ai_assistant_view_search"/>
        <field name="context">{'search_default_active': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first AI Assistant
            </p>
            <p>
                AI Assistants are virtual employees with names and email addresses.
                They can respond to emails, Slack messages, and perform automated tasks.
            </p>
        </field>
    </record>
</odoo>
