<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron: Check low stock daily at 06:00 -->
        <record id="cron_check_low_stock" model="ir.cron">
            <field name="name">AI: Check Low Stock</field>
            <field name="model_id" ref="stock.model_stock_quant"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_low_stock()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>

        <!-- Cron: Check contract renewals daily at 06:30 -->
        <record id="cron_check_contract_renewals" model="ir.cron">
            <field name="name">AI: Check Contract Renewals</field>
            <field name="model_id" ref="model_arc_contract"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_contract_renewals()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
