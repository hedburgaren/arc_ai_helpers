<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- AI Helpers Module Category -->
        <record id="module_category_ai_helpers" model="ir.module.category">
            <field name="name">AI Helpers</field>
            <field name="description">AI-powered assistants and automation</field>
            <field name="sequence">100</field>
        </record>

        <!-- User Group -->
        <record id="group_ai_user" model="res.groups">
            <field name="name">AI User</field>
            <field name="category_id" ref="module_category_ai_helpers"/>
            <field name="comment">Can use AI assistants and view tasks</field>
        </record>

        <!-- Manager Group -->
        <record id="group_ai_manager" model="res.groups">
            <field name="name">AI Manager</field>
            <field name="category_id" ref="module_category_ai_helpers"/>
            <field name="implied_ids" eval="[(4, ref('group_ai_user'))]"/>
            <field name="comment">Can configure AI assistants and settings</field>
        </record>

        <!-- Admin Group -->
        <record id="group_ai_admin" model="res.groups">
            <field name="name">AI Administrator</field>
            <field name="category_id" ref="module_category_ai_helpers"/>
            <field name="implied_ids" eval="[(4, ref('group_ai_manager'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
            <field name="comment">Full access to AI configuration including API keys</field>
        </record>

        <!-- AI Assistant Bot Group (for auto-created AI users) -->
        <record id="group_ai_assistant_bot" model="res.groups">
            <field name="name">AI Assistant (Bot)</field>
            <field name="category_id" ref="module_category_ai_helpers"/>
            <field name="comment">Auto-created users for AI assistants. Minimal permissions, used for @mentions and Discuss integration.</field>
        </record>
    </data>

    <data noupdate="0">
        <!-- Record Rules for Multi-Company Isolation -->
        
        <!-- AI Assistant: Company Rule -->
        <record id="ai_assistant_company_rule" model="ir.rule">
            <field name="name">AI Assistant: Company</field>
            <field name="model_id" ref="model_ai_assistant"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Task: Company Rule -->
        <record id="ai_task_company_rule" model="ir.rule">
            <field name="name">AI Task: Company</field>
            <field name="model_id" ref="model_ai_task"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Settings: Company Rule -->
        <record id="ai_settings_company_rule" model="ir.rule">
            <field name="name">AI Settings: Company</field>
            <field name="model_id" ref="model_ai_settings"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Log: Company Rule -->
        <record id="ai_log_company_rule" model="ir.rule">
            <field name="name">AI Log: Company</field>
            <field name="model_id" ref="model_ai_log"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Context: Company Rule -->
        <record id="ai_context_company_rule" model="ir.rule">
            <field name="name">AI Context: Company</field>
            <field name="model_id" ref="model_ai_context"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- AI Prompt Template: Company Rule -->
        <record id="ai_prompt_template_company_rule" model="ir.rule">
            <field name="name">AI Prompt Template: Company</field>
            <field name="model_id" ref="model_ai_prompt_template"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        </record>
    </data>
</odoo>
